#include <stdio.h>
#include <limits.h>

int m[20][20], s[20][20];
void printOptimal(int i, int j)
{
    if (i == j)
    {
        printf("A%d", i);
    }
    else
    {
        printf("(");
        printOptimal(i, s[i][j]);
        printOptimal(s[i][j] + 1, j);
        printf(")");
    }
}
void matrixChainOrder(int p[], int n)
{
    int i, j, k, L, q;


    for (i = 1; i <= n; i++)
        m[i][i] = 0;
    for (L = 2; L <= n; L++)
    {
        for (i = 1; i <= n - L + 1; i++)
        {
            j = i + L - 1;
            m[i][j] = INT_MAX;

            for (k = i; k < j; k++)
            {
                q = m[i][k] + m[k + 1][j]
                    + p[i - 1] * p[k] * p[j];

                if (q < m[i][j])
                {
                    m[i][j] = q;
                    s[i][j] = k;
                }
            }
        }
    }
    printf("\n                    DP COST MATRIX (m)\n\n");
    printf("%8s", "");

    for (j = 1; j <= n; j++)
    {
        char col[10];
        sprintf(col, "A%d", j);
        printf("%8s", col);
    }

    printf("\n");
    for (i = 1; i <= n; i++)
    {
        char row[10];
        sprintf(row, "A%d", i);

        printf("%8s", row);

        for (j = 1; j <= n; j++)
        {
            if (j < i)
                printf("%8s", "-");
            else
                printf("%8d", m[i][j]);
        }

        printf("\n");
    }
    printf("\n                         K MATRIX (s)\n\n6");
    printf("%8s", "");

    for (j = 1; j <= n; j++)
    {
        char col[10];
        sprintf(col, "A%d", j);
        printf("%8s", col);
    }

    printf("\n");
    for (i = 1; i <= n; i++)
    {
        char row[10];
        sprintf(row, "A%d", i);

        printf("%8s", row);

        for (j = 1; j <= n; j++)
        {
            if (j <= i)
                printf("%8s", "-");
            else
                printf("%8d", s[i][j]);
        }

        printf("\n");
    }
    printf("\n                 OPTIMAL PARENTHESIZATION\n\n");
    printf("Order : ");
    printOptimal(1, n);

    printf("\n\nMinimum Scalar Multiplications = %d\n", m[1][n]);
}

int main()
{
    int n;

  
    printf("            MATRIX CHAIN MULTIPLICATION PROGRAM\n");
    printf("\nEnter number of matrices : ");
    scanf("%d", &n);
    int p[n + 1];
    printf("\nEnter dimensions of matrices:\n");
    for (int i = 1; i <= n; i++)
    {
        int row, col;

        printf("Enter dimensions of A%d : ", i);
        scanf("%d %d", &row, &col);

        if (i == 1)
            p[0] = row;
        p[i] = col;
    }
    matrixChainOrder(p, n);
    return 0;
}



//server
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>

#define PORT 25020
#define BUFFER_SIZE 4096

int main() {
    int listenfd, connfd;
    struct sockaddr_in serv_addr;
    char buffer[BUFFER_SIZE], output[BUFFER_SIZE];

    listenfd = socket(AF_INET, SOCK_STREAM, 0);
    int opt = 1;
    setsockopt(listenfd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));

    serv_addr.sin_family = AF_INET;
    serv_addr.sin_port = htons(PORT);
    serv_addr.sin_addr.s_addr = INADDR_ANY;

    bind(listenfd, (struct sockaddr*)&serv_addr, sizeof(serv_addr));
    listen(listenfd, 5);
    printf("Remote Command Server Running on Port %d...\n", PORT);

    while(1) {
        connfd = accept(listenfd, NULL, NULL);
        printf("Client connected.\n");
        
        while(1) {
            memset(buffer, 0, BUFFER_SIZE);
            if (read(connfd, buffer, BUFFER_SIZE) <= 0) break;
            if (strncmp(buffer, "exit", 4) == 0) break;

            printf("Running command: %s\n", buffer);

            // popen executes the command and opens a pipe to read output
            FILE *fp = popen(buffer, "r");
            if (fp == NULL) {
                write(connfd, "TEXT:Error running command\n", 27);
                continue;
            }

            memset(output, 0, BUFFER_SIZE);
            char line[256];
            int line_count = 0;
            while (fgets(line, sizeof(line), fp)) {
                strcat(output, line);
                line_count++;
            }
            pclose(fp);

            if (line_count <= 1) {
                // Single line output
                char res[BUFFER_SIZE + 10];
                sprintf(res, "TEXT:%s", output);
                write(connfd, res, strlen(res));
            } else {
                // Multi-line output: Write to file
                FILE *file_ptr = fopen("cmd_output.txt", "w");
                fprintf(file_ptr, "%s", output);
                fclose(file_ptr);
                
                char res[BUFFER_SIZE + 30];
                sprintf(res, "FILE:cmd_output.txt\n%s", output);
                write(connfd, res, strlen(res));
            }
        }
        close(connfd);
        printf("Client disconnected. Waiting for new connection...\n");
    }
    return 0;
}



