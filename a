#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>

#define PORT 25020

int main() {
    int sockfd;
    struct sockaddr_in serv_addr;
    char buffer[4096];

    sockfd = socket(AF_INET, SOCK_STREAM, 0);
    serv_addr.sin_family = AF_INET;
    serv_addr.sin_port = htons(PORT);
    inet_aton("127.0.0.1", &serv_addr.sin_addr);

    if (connect(sockfd, (struct sockaddr*)&serv_addr, sizeof(serv_addr)) < 0) {
        perror("Connect failed");
        return 1;
    }
    printf("Connected! Type commands (ls, pwd, date, etc) or 'exit'.\n");

    while(1) {
        printf("cmd> ");
        fgets(buffer, 1024, stdin);
        buffer[strcspn(buffer, "\n")] = 0;

        write(sockfd, buffer, strlen(buffer));
        if (strcmp(buffer, "exit") == 0) break;

        memset(buffer, 0, 4096);
        int r = read(sockfd, buffer, 4095);
        if (r <= 0) break;

        if (strncmp(buffer, "TEXT:", 5) == 0) {
            printf("[Single Line Result]: %s", buffer + 5);
        } else if (strncmp(buffer, "FILE:", 5) == 0) {
            printf("[Multi-line Result - Saved on Server]:\n%s", buffer + 5);
        }
    }
    close(sockfd);
    return 0;
}

